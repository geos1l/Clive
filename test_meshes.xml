<mujoco model="mesh_test">
  <compiler meshdir="meshes" autolimits="true"/>

  <asset>
    <mesh name="cape"  file="cape.stl"/>
    <mesh name="clock" file="clock_head.stl"/>
  </asset>

  <worldbody>
    <light pos="0 -0.4 0.5" dir="0 0.4 -1"/>
    <geom type="plane" size="0.5 0.5 0.05" rgba="0.85 0.85 0.9 1"/>

    <!-- Cape mesh, sitting on the ground at left -->
    <body pos="-0.12 0 0">
      <geom type="mesh" mesh="cape" rgba="0.22 0.42 0.92 1"/>
    </body>

    <!-- Clock-head mesh, sitting on the ground at right -->
    <body pos="0.12 0 0.05">
      <geom type="mesh" mesh="clock" rgba="0.94 0.93 0.88 1"/>
    </body>
  </worldbody>
</mujoco>
